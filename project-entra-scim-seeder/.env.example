# Entra ID App Registration (App-Directory-Seeder)
TENANT_ID=your-tenant-id-guid
CLIENT_ID=your-app-registration-client-id
CLIENT_SECRET=your-client-secret-value

# Domain suffix for UPN generation
DOMAIN=yourdomain.onmicrosoft.com

# Azure Key Vault (SCIM Gateway runtime)
KEY_VAULT_URL=https://your-keyvault.vault.azure.net/
SCIM_BEARER_TOKEN_SECRET_NAME=scim-bearer-token

# SCIM Gateway local dev fallback
SCIM_BEARER_TOKEN=local-dev-token-value
